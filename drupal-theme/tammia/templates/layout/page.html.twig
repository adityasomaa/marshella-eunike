{#
/**
 * @file
 * Tammia theme: page layout.
 * Mirrors the approved tammia-online preview: shipping ticker, sticky pill nav
 * with Tammia logo, content, dark footer with white logo.
 *
 * Region mapping (lihat tammia.info.yml):
 * - shipping_bar  : ticker promo di atas nav (opsional)
 * - primary_menu  : menu utama (fallback: link statis di bawah)
 * - content       : isi halaman / Commerce
 * - footer_*      : kolom footer
 */
#}

{# ---------- Shipping ticker ---------- #}
{% if page.shipping_bar %}
  {{ page.shipping_bar }}
{% else %}
  <div class="shipping-bar">
    <div class="ticker">
      <span>Gratis ongkir untuk pesanan 150K+</span>
      <span>100% produk original</span>
      <span>Beauty starts with the right tools</span>
      <span>Tukar 7 hari · syarat berlaku</span>
    </div>
  </div>
{% endif %}

{# ---------- Navbar ---------- #}
<header class="nav-wrap">
  <div class="container">
    <nav class="navbar-tammia" aria-label="{{ 'Main navigation'|t }}">
      <a href="{{ path('<front>') }}" class="brand-logo" rel="home">
        <img src="{{ base_path ~ directory }}/img/logos/tammia-red.png" alt="{{ site_name }}" class="brand-logo-img">
        
      </a>

      {% if page.primary_menu %}
        {{ page.primary_menu }}
      {% else %}
        <ul class="nav-menu d-none d-lg-flex">
          <li><a href="{{ path('<front>') }}">Home</a></li>
          <li><a href="{{ base_path }}shop">Shop</a></li>
          <li><a href="{{ base_path }}about">Tentang</a></li>
          <li><a href="{{ base_path }}contact">Kontak</a></li>
        </ul>
      {% endif %}

      <div class="nav-icons ms-auto d-flex align-items-center gap-2">
        <a href="{{ base_path }}search" class="nav-icon-btn" aria-label="{{ 'Search'|t }}"><i class="bi bi-search"></i></a>
        <a href="{{ base_path }}user" class="nav-icon-btn" aria-label="{{ 'Account'|t }}"><i class="bi bi-person"></i></a>
        <a href="{{ base_path }}cart" class="nav-icon-btn position-relative" aria-label="{{ 'Cart'|t }}">
          <i class="bi bi-bag"></i>
        </a>
      </div>
    </nav>
  </div>
</header>

{# ---------- Highlighted / messages ---------- #}
{% if page.highlighted %}
  <div class="container mt-3">{{ page.highlighted }}</div>
{% endif %}

{% if page.breadcrumb %}
  <div class="container mt-3">{{ page.breadcrumb }}</div>
{% endif %}

{# ---------- Main content ---------- #}
<main id="main-content" role="main">
  {% if page.sidebar_first %}
    <div class="container">
      <div class="row g-4">
        <aside class="col-lg-3">{{ page.sidebar_first }}</aside>
        <div class="col-lg-9">{{ page.content }}</div>
      </div>
    </div>
  {% else %}
    {{ page.content }}
  {% endif %}
</main>

{# ---------- Footer ---------- #}
<footer class="site-footer">
  <div class="container">
    <div class="row g-5 pb-4">
      <div class="col-lg-4">
        <a href="{{ path('<front>') }}" class="brand-logo">
          <img src="{{ base_path ~ directory }}/img/logos/tammia-white.png" alt="{{ site_name }}" class="brand-logo-img">
          
        </a>
        <p class="mt-3" style="color:#b0b0b0; font-size:14px; max-width:320px;">
          Beauty starts with the right tools. Koleksi beauty tools original
          dari brand internasional pilihan.
        </p>
        {#
          Social links Tammia resmi (samakan dengan preview). Idealnya
          dipindah ke block/menu Drupal saat integrasi agar mudah diedit admin.
        #}
        <div class="footer-social">
          <a href="https://www.instagram.com/tammia_indonesia/" target="_blank" rel="noopener" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
          <a href="https://www.facebook.com/TammiaOnline" target="_blank" rel="noopener" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
          <a href="https://www.tiktok.com/@tammiaonline" target="_blank" rel="noopener" aria-label="TikTok"><i class="bi bi-tiktok"></i></a>
          <a href="https://wa.me/62818883349?text=Halo%20Tammia%20Online%20%F0%9F%91%8B%20Saya%20mau%20tanya-tanya%20seputar%20produk%20beauty%20tools-nya." target="_blank" rel="noopener" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
        </div>
      </div>
      <div class="col-6 col-lg-2">{{ page.footer_first }}</div>
      <div class="col-6 col-lg-2">{{ page.footer_second }}</div>
      <div class="col-12 col-lg-4">{{ page.footer_third }}</div>
    </div>
    <div class="footer-bottom d-flex flex-wrap justify-content-between align-items-center gap-2 pt-4" style="border-top:1px solid rgba(255,255,255,0.12);">
      <span style="color:#b0b0b0; font-size:13px;">© {{ 'now'|date('Y') }} Tammia Online · PT Tammia Beauty Indonesia</span>
      {{ page.footer_bottom }}
    </div>
  </div>
</footer>
